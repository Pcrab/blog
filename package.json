{
    "name": "blog",
    "version": "0.0.0",
    "private": true,
    "keywords": [],
    "description": "Personal blog site generator",
    "author": {
        "email": "pcrab@pcrab.xyz",
        "name": "Pcrab",
        "url": "https://github.com/Pcrab"
    },
    "license": "GPL-v3",
    "scripts": {
        "astro": "astro",
        "build:hexo": "node scripts/initHexo.js",
        "build:astro": "astro build",
        "build": "pnpm build:hexo && pnpm build:astro",
        "dev:astro": "astro dev",
        "dev:hexo": "node scripts/initHexo.js",
        "dev": "pnpm dev:hexo && pnpm dev:astro",
        "clean": "rimraf \"**/node_modules\"",
        "commitlint": "commitlint",
        "format:check": "pnpm format --check --debug-check",
        "format:fix": "pnpm format --write",
        "freshinstall": "pnpm clean && pnpm i",
        "nuke": "rimraf pnpm-lock.yaml && pnpm freshinstall",
        "preview": "astro preview",
        "start": "astro dev",
        "syncpack:fix": "syncpack format && syncpack fix-mismatches",
        "prepare": "husky"
    },
    "type": "module",
    "main": "index.js",
    "dependencies": {
        "@astrojs/sitemap": "^3.4.2",
        "@astrojs/tailwind": "^6.0.2",
        "@tailwindcss/typography": "^0.5.16",
        "astro": "^5.12.8",
        "astro-robots-txt": "^1.0.0",
        "dayjs": "^1.11.13",
        "hexo": "^7.3.0",
        "hexo-highlight-shiki": "2.1.0",
        "hexo-renderer-marked": "^7.0.1",
        "node-html-parser": "^7.0.1",
        "posthtml": "^0.16.6",
        "tailwindcss": "^4.1.11"
    },
    "devDependencies": {
        "@astrojs/ts-plugin": "^1.10.4",
        "@commitlint/cli": "^19.8.1",
        "@types/node": "^24.1.0",
        "@unocss/reset": "66.3.3",
        "husky": "^9.1.7",
        "rimraf": "^6.0.1",
        "syncpack": "^13.0.4",
        "typescript": "^5.9.2",
        "unocss": "66.3.3"
    },
    "hexo": {
        "version": "7.3.0"
    },
    "packageManager": "pnpm@10.5.2+sha512.da9dc28cd3ff40d0592188235ab25d3202add8a207afbedc682220e4a0029ffbff4562102b9e6e46b4e3f9e8bd53e6d05de48544b0c57d4b0179e22c76d1199b",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "hexo-highlight-shiki",
            "hexo-util",
            "sharp"
        ]
    }
}
